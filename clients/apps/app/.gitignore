# Rapidly mobile — ignored artifacts for the Expo / React Native app.

# ── Dependencies ──
node_modules/

# ── Expo / React Native ──
.expo/
dist/
web-build/
expo-env.d.ts
/ios
/android

# ── Native signing / credentials ──
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ── Metro bundler ──
.metro-health-check*

# ── Debug logs ──
npm-debug.*
yarn-debug.*
yarn-error.*

# ── OS / editor ──
.DS_Store
*.pem

# ── Environment secrets ──
.env*.local
.env.local

# ── Firebase credentials (restrict key in Firebase console) ──
google-services.json

# ── TypeScript incremental ──
*.tsbuildinfo

# ── Scaffolding ──
app-example

RAPIDLY_ENV=development
RAPIDLY_LOG_LEVEL=DEBUG
RAPIDLY_TESTING=0
RAPIDLY_SQLALCHEMY_DEBUG=0
RAPIDLY_POSTHOG_DEBUG=1

RAPIDLY_CORS_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'
RAPIDLY_ALLOWED_HOSTS='["localhost:3000", "127.0.0.1:3000"]'
RAPIDLY_FRONTEND_BASE_URL="http://127.0.0.1:3000"

RAPIDLY_USER_SESSION_COOKIE_DOMAIN="127.0.0.1"

RAPIDLY_POSTGRES_USER=rapidly
RAPIDLY_POSTGRES_PWD=rapidly
RAPIDLY_POSTGRES_HOST=127.0.0.1
RAPIDLY_POSTGRES_PORT=5433
RAPIDLY_POSTGRES_DATABASE=rapidly

RAPIDLY_POSTGRES_READ_USER=rapidly_read
RAPIDLY_POSTGRES_READ_PWD=rapidly
RAPIDLY_POSTGRES_READ_HOST=127.0.0.1
RAPIDLY_POSTGRES_READ_PORT=5433
RAPIDLY_POSTGRES_READ_DATABASE=rapidly

RAPIDLY_REDIS_HOST=127.0.0.1
RAPIDLY_REDIS_PORT=6380
RAPIDLY_REDIS_DB=0

RAPIDLY_MICROSOFT_CLIENT_ID="__UNSET__"
RAPIDLY_MICROSOFT_CLIENT_SECRET="__UNSET__"
RAPIDLY_MICROSOFT_TENANT="common"

RAPIDLY_STRIPE_SECRET_KEY="*** REPLACE ***"
RAPIDLY_STRIPE_PUBLISHABLE_KEY="*** REPLACE ***"
RAPIDLY_STRIPE_WEBHOOK_SECRET="*** REPLACE ***"
RAPIDLY_STRIPE_CONNECT_WEBHOOK_SECRET="*** REPLACE ***"

# Frontend environment variables (used by web container in Docker dev)
NEXT_PUBLIC_STRIPE_KEY="*** REPLACE ***"

RAPIDLY_GOOGLE_CLIENT_ID = "*** REPLACE ***"
RAPIDLY_GOOGLE_CLIENT_SECRET = "*** REPLACE ***"


# Object Storage (Cloudflare R2 in production, MinIO for local dev)
# R2 uses S3-compatible API — same env vars work for both
RAPIDLY_AWS_ACCESS_KEY_ID=rapidly-development
RAPIDLY_AWS_SECRET_ACCESS_KEY=rapidly123456789
RAPIDLY_S3_FILES_BUCKET_NAME="rapidly-s3"
RAPIDLY_S3_FILES_PUBLIC_BUCKET_NAME="rapidly-s3-public"
RAPIDLY_S3_ENDPOINT_URL="http://127.0.0.1:9010"
RAPIDLY_MINIO_USER=rapidly
# MinIO requires minimum 8 chars password / access key (local dev only)
RAPIDLY_MINIO_PWD=rapidlyrapidly

# Prometheus Remote Write (for local dev with docker compose --profile monitoring)
RAPIDLY_PROMETHEUS_REMOTE_WRITE_URL=http://localhost:9091/api/v1/write

RAPIDLY_APP_REVIEW_EMAIL = "*** REPLACE ***"
RAPIDLY_APP_REVIEW_OTP_CODE = "*** REPLACE ***"

# File Sharing / P2P (COTURN TURN relay for WebRTC)
# Channel TTL in seconds (default: 3600 = 1 hour)
RAPIDLY_FILE_SHARING_CHANNEL_TTL=3600
# STUN server for WebRTC ICE gathering
RAPIDLY_FILE_SHARING_STUN_SERVER="stun.l.google.com:19302"
# COTURN TURN relay (required for peers behind strict NAT/firewalls)
RAPIDLY_FILE_SHARING_COTURN_ENABLED=false
RAPIDLY_FILE_SHARING_TURN_HOST="127.0.0.1"
RAPIDLY_FILE_SHARING_TURN_PORT=3478
RAPIDLY_FILE_SHARING_TURN_TLS_PORT=5349
# Shared secret for COTURN ephemeral credentials (must match docker-compose.coturn.yml)
RAPIDLY_FILE_SHARING_TURN_SECRET="*** REPLACE ***"
RAPIDLY_FILE_SHARING_TURN_CREDENTIAL_TTL=86400

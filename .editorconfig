# Rapidly editor configuration — https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8
end_of_line = lf
max_line_length = 120

[*.py]
indent_size = 4
max_line_length = 100

[*.md]
indent_size = 4
trim_trailing_whitespace = false

[*.{tsx,ts,jsx,js}]
indent_size = 2
max_line_length = 100

[*.mustache]
insert_final_newline = false

[Makefile]
indent_style = tab

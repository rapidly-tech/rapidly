# Rapidly Development Secrets
# Copy to ~/.config/rapidly/secrets.env and fill in values
#
# This file is used to share secrets across multiple Git worktrees.
# Run ./dev/setup-environment to automatically merge these into server/.env

# GitHub OAuth - create app at https://github.com/settings/apps
# Or run: ./dev/setup-environment --setup-github-app
RAPIDLY_GITHUB_CLIENT_ID=
RAPIDLY_GITHUB_CLIENT_SECRET=
RAPIDLY_GITHUB_APP_WEBHOOK_SECRET=
RAPIDLY_GITHUB_APP_IDENTIFIER=
RAPIDLY_GITHUB_APP_PRIVATE_KEY=
RAPIDLY_GITHUB_APP_NAMESPACE=

# GitHub Repository Benefits App (usually same as above)
RAPIDLY_GITHUB_REPOSITORY_BENEFITS_APP_NAMESPACE=
RAPIDLY_GITHUB_REPOSITORY_BENEFITS_APP_IDENTIFIER=
RAPIDLY_GITHUB_REPOSITORY_BENEFITS_APP_PRIVATE_KEY=
RAPIDLY_GITHUB_REPOSITORY_BENEFITS_CLIENT_ID=
RAPIDLY_GITHUB_REPOSITORY_BENEFITS_CLIENT_SECRET=

# Stripe - from https://dashboard.stripe.com/test/apikeys
RAPIDLY_STRIPE_SECRET_KEY=
RAPIDLY_STRIPE_PUBLISHABLE_KEY=
RAPIDLY_STRIPE_WEBHOOK_SECRET=
RAPIDLY_STRIPE_CONNECT_WEBHOOK_SECRET=

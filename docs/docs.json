{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "appearance": {
    "default": "system"
  },
  "name": "Rapidly",
  "description": "Secure file sharing with built-in payments. End-to-end encrypted, peer-to-peer.",
  "colors": {
    "primary": "#000",
    "light": "#fff",
    "dark": "#000"
  },
  "background": {
    "color": {
      "dark": "#131316"
    }
  },
  "favicon": "./logo/favicon.png",
